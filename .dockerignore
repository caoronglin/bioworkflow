# Docker Ignore File - Exclude unnecessary files from build context
# Reference: https://docs.docker.com/build/building/context/#dockerignore-files

# Git
.git
.gitignore
.gitattributes

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
.circleci

# IDE
.vscode
.idea
*.swp
*.swo
*~

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov/
.tox/
.nox/

# Virtual environments
.venv
venv/
ENV/
env/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Frontend build (will be built fresh)
src/frontend/dist
src/frontend/.output
src/frontend/.nuxt
src/frontend/.vite

# Rust
rust/target/
**/*.rs.bk

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
docs/
*.md
!README.md
LICENSE

# Tests
tests/
test/
**/__tests__/**
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/*.spec.js

# Environment files
.env
.env.*
!.env.example

# Secrets
*.pem
*.key
*.crt
secrets/

# OS files
.DS_Store
Thumbs.db

# Build artifacts
*.log
*.tmp
*.temp