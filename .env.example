# BioWorkflow 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# ==================== 应用配置 ====================
DEBUG=true
VERSION=0.1.0
ENVIRONMENT=development

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=8000
FRONTEND_PORT=5173

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///./bioworkflow.db

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0

# ==================== JWT 配置 ====================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== Snakemake 配置 ====================
SNAKEMAKE_WORKDIR=./workflows
SNAKEMAKE_CONDA_PREFIX=./conda_envs

# ==================== Conda 配置 ====================
CONDA_CHANNELS=conda-forge,bioconda,defaults

# ==================== 知识库配置 ====================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
KNOWLEDGE_BASE_DIR=./knowledge_base

# ==================== MCP 配置 ====================
MCP_SERVICE_TIMEOUT=30

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=./logs/bioworkflow.log
